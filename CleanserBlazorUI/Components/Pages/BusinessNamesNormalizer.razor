    {
        // BusSettNormalizer item = new();
        // item = _item;
        // isEditselected = true;
        // id = item.Id;
        // dataType = SettingsDataType.BusinessNamenormalizer;
        // dateCreated = item.DateCreated;
        // dateModified = item.DateModified;
        // short_value = item.ShortValue;
        // long_value = item.LongValue;
        // await InvokeAsync(StateHasChanged);
    }
    public async Task ShowTextForThreeSecondsAsync(bool isSuccussfullyAdd, CancellationToken cancellationToken)
    {
        try
        {
            if (isSuccussfullyAdd)
            {
                AlertSeverityVisible = "d-block";
                AlertSeverity = MudBlazor.Severity.Success;
                AlertSeverityMessage = "Added successfully";
            }
            else
            {
                AlertSeverityVisible = "d-block";
                AlertSeverity = MudBlazor.Severity.Error;
                AlertSeverityMessage = "Already Exits";
            }
            await InvokeAsync(StateHasChanged);
            await Task.Delay(3000, cancellationToken);
            AlertSeverityVisible = "d-none";
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException)
        {
        }
    }
}