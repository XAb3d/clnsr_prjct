    (List<DBIndividualContext> _individualContext, string _correctDateOfBirth, string _dobIssues, string _matchdata) REF_MainMatcherTransformer_IND(List<IndividualRef> savedDatafromOurDatabase, List<DBIndividualContext> recordFromClient)
    {
        int correctDateOfBirth = 0; int dobIssues = 0; int matchdata = 0;

        // Build O(1) lookup index — avoids O(n²) FirstOrDefault inside loop
        var savedIndex = savedDatafromOurDatabase.ToDictionary(
            r => (NormalizeAccountNumber(r.CreditFacilityAccNum),
                  NormalizeCustomerId(r.CustomerID),
                  r.DisbursementDate ?? string.Empty),
            r => r
        );

        foreach (var clientRecord in recordFromClient)
        {
            var key = (NormalizeAccountNumber(clientRecord.CreditFacilityAccNum),
                       NormalizeCustomerId(clientRecord.CustomerID),
                       clientRecord.DisbursementDate ?? string.Empty);

            if (!savedIndex.TryGetValue(key, out var matchingSavedRecord))
            {
                clientRecord.Status = string.Empty;
                matchdata++;
            }
            else
            {
                if (matchingSavedRecord.DateOfBirth == clientRecord.DateOfBirth)
                {
                    clientRecord.Status = string.Empty;
                    correctDateOfBirth++;
                }
                else
                {
                    clientRecord.Status = "DOB";
                    dobIssues++;
                }
            }
        }
        return (recordFromClient, correctDateOfBirth.ToString(), dobIssues.ToString(), matchdata.ToString());
    }
