    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_jsInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("initializeDragAndDrop", DropZone);
                _jsInitialized = true; // Ensure JS is initialized only once
            }
            catch (Exception ex)
            {
            }
        }
    }
    async Task REF_FileUpload(InputFileChangeEventArgs e)
    {
        Logger.LogInformation("File upload started with {FileCount} files.", e.GetMultipleFiles(MAX_FILES).Count);
        REF_ResetVariables();
        isLoading = true;
        GetErrorsPairsList.Clear();


        foreach (var browserFile in e.GetMultipleFiles(MAX_FILES))
        {
            try
            {
                var bbb = stringHelper.GetBusinessTypeFromFile(browserFile.Name);
                var shortname = await DataManagementService.GetShortCodefromReferencing(browserFile.Name, stringHelper.GetBusinessTypeFromFile(browserFile.Name).ToLower());
                var extension = Path.GetExtension(browserFile.Name);
                // if (browserFile != null && extension == ".xlsx" && await REF_CheckFileNamesAllowed(browserFile))
                //if (browserFile != null && extension == ".xlsx")
                if (browserFile != null && extension == ".xlsx" && !string.IsNullOrWhiteSpace(shortname))
                {
                    spreadsheetFileAndChipColor.Add(new SpreadsheetFileAndChipColor { SpreadsheetFile = browserFile, SpreadsheetFileColor = Color.Primary, IsPassed = true });
                }
                else
                {
                    spreadsheetFileAndChipColor.Add(new SpreadsheetFileAndChipColor { SpreadsheetFile = browserFile, SpreadsheetFileColor = Color.Error, IsPassed = false });
                    numberofFileswithoutreference++;
                }
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error processing file {FileName}", browserFile.Name);
            }

        }
        if (numberofFileswithoutreference > 0)
        {
            ToggleCleaningViewOrRefView(2);
        }
        else
        {
            ToggleCleaningViewOrRefView(1);
        }
        StateHasChanged();
        currentFileCount = spreadsheetFileAndChipColor.Count;
        isLoading = false;
        Logger.LogInformation("File upload finished. {ValidFiles} valid files, {InvalidFiles} invalid files.", spreadsheetFileAndChipColor.Count(f => f.IsPassed), spreadsheetFileAndChipColor.Count(f => !f.IsPassed));
    }
    void REF_RemoveFile(SpreadsheetFileAndChipColor file)
    {
        spreadsheetFileAndChipColor.Remove(file);
        currentFileCount = spreadsheetFileAndChipColor.Count;
        StateHasChanged();
    }
    void REF_ClearSeletedFiles()
    {
        spreadsheetFileAndChipColor.Clear();
        currentFileCount = spreadsheetFileAndChipColor.Count;
        fullPastFilesPaths.Clear();
        fullFailedFilesPaths.Clear();
        REF_ResetVariables();
        StateHasChanged();
    }
    void REF_OnPanelExpandedChanged(string selectedPanel)
    {
        REF_ClearSeletedFiles();
    }
    async Task REF_DownloadExcelDataStream(byte[] excelData, string targetFilePath)
    {
        string SecuredFileNameOrRawFileName = targetFilePath!;
        if (PRINT_EXCEL_WITH_SECURED_NAME)
        {
            SecuredFileNameOrRawFileName = Path.GetFileName(targetFilePath!);
        }
        else { SecuredFileNameOrRawFileName = REF_GetFileNameFromFile(targetFilePath!); }
        // Trigger download using JavaScript Interop
        await JS.InvokeVoidAsync("downloadFile", SecuredFileNameOrRawFileName, excelData, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
        File.Delete(FullExcelDataFilePath!);
    }
    string REF_GetFileNameFromFile(string path)
    {
        string item = Path.GetFileName(path);
        item = item.Split("_____")[1];
        item = item.Replace(".xlsx", "_TBC.xlsx");
        return item;
    }
    void REF_ResetVariables()
    {
        passedRecord.Clear();
        failedRecord.Clear();
        numberOfPassedCount = $"Passed Files (0)";
        numberOffailedCount = "0";
        fullPastFilesPaths.Clear();
        fullFailedFilesPaths.Clear();
    }
    List<string> REF_GetAllFailedFileLenght()
    {
        List<string> _allfailedfiles = new();
        foreach (var item in fullFailedFilesPaths ?? new List<string>())
        {
            _allfailedfiles.Add(REF_GetFileNameFromFile(item));
        }
        return _allfailedfiles;
    }
    async Task<byte[]> REF_SaveToExcelAsync<T>(List<T> context)
    {
        return await Task.Run(() =>
        {

            using (var wb = new XLWorkbook())
            {
                var ws = wb.Worksheets.Add("TBC");
                var wsu = wb.Worksheets.Add("DOB ERRORS");
                var wsd = wb.Worksheets.Add("DUPLICATE");

                if (typeof(T) == typeof(DBBusinessContext))
                {
                    REF_WriteHeaders(ws, wsu, wsd, SpreadSheetHeadersData.Business, 159);
                    REF_WriteData(context.OfType<DBBusinessContext>().ToList(), ws, wsu);
                }
                else if (typeof(T) == typeof(DBIndividualContext))
                {
                    REF_WriteHeaders(ws, wsu, wsd, SpreadSheetHeadersData.Individual, 179);
                    REF_WriteData(context.OfType<DBIndividualContext>().ToList(), ws, wsu);
                }

                using var stream = new MemoryStream();
                wb.SaveAs(stream);
                return stream.ToArray();
            }
        });
    }
