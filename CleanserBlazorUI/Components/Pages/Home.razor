    bool REF_IsDateOfBirtWrong<T>(T context) where T : class
    {
        if (typeof(T) == typeof(DBBusinessContext))
        {
            var bc = context as DBBusinessContext;
            if (string.IsNullOrWhiteSpace(bc.Status))
            {
                return true;
            }
        }
        else if (typeof(T) == typeof(DBIndividualContext))
        {
            var ic = context as DBIndividualContext;
            if (string.IsNullOrWhiteSpace(ic.Status))
            {
                return true;
            }
        }
        return false;
    }
 
    
