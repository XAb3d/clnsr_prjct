    (List<BusinessContext> allRecords, List<BusinessContext> duplicatesInd, string correctDateOfBirth, string dobIssues, string matchdata, string newdata, string duplicatescount) REF_MainMatcherTransformerInd_Clean_BUS(List<BusinessRef> fromDatabase, List<BusinessContext> fromExcelFile, bool handleDuplicates = true)
    {
        List<BusinessContext> processedExcelRecords = new();
        List<BusinessContext> duplicatesList = new();

        if (handleDuplicates)
        {
            var seenKeys = new HashSet<(string, string, string?)>();
            processedExcelRecords = new List<BusinessContext>();
            foreach (var record in fromExcelFile)
            {
                var key = (NormalizeAccountNumber(record.Facilityaccnum?.Data), NormalizeCustomerId(record.CustomerID?.Data), record.DisbursementDate?.Data);
                if (seenKeys.Contains(key))
                {
                    duplicatesList.Add(record); // Duplicates stored separately //
                }
                else
                {
                    seenKeys.Add(key);
                    processedExcelRecords.Add(record); // Processed records exclude duplicates
                }
            }
        }
        else
        {
            processedExcelRecords = fromExcelFile.ToList();
        }

        var databaseDict = new Dictionary<(string, string), BusinessRef>();
        foreach (var dbRecord in fromDatabase)
        {
            var key = (NormalizeAccountNumber(dbRecord.CreditFacilityAccNum), NormalizeCustomerId(dbRecord.CustomerID));
            databaseDict[key] = dbRecord;
        }

        int __correctDateOfBirth = 0;
        int __dobIssues = 0;
        int __matchdata = 0;
        int __newdata = 0;
        int __burscount = 0;

        foreach (var excelRecord in processedExcelRecords)
        {
            var creditFacilityAccNum = NormalizeAccountNumber(excelRecord.Facilityaccnum?.Data);
            var customerID = NormalizeCustomerId(excelRecord.CustomerID?.Data);
            var disbursementDate = excelRecord.DisbursementDate?.Data;

            var key = (creditFacilityAccNum, customerID);

            if (databaseDict.TryGetValue(key, out var dbRecord))
            {
                var excelDob = excelRecord.DateOfBirth;
                __matchdata++;
                if (dbRecord.DisbursementDate != disbursementDate)
                {
                    excelRecord.DisburStatus = " THE DISBURSEMENT DATE DOES NOT MATCH THE PREVIOUS SUBMISSION ";
                    __burscount++;
                }
                if (dbRecord.DateOfBirth == excelDob)
                {
                    __correctDateOfBirth++;
                }
                else
                {
                    excelRecord.Status = "DOB";
                    __dobIssues++;
                }
            }
            else
            {
                __newdata++;
            }
        }

        return (processedExcelRecords, duplicatesList, "N/A", "N/A", __matchdata.ToString(), __newdata.ToString(), duplicatesList.Count.ToString());
    }
    List<BusinessContext> CheckForChangesInCustomerIDBusregnumTinum(List<BusinessContext> list)
    {
        if (list == null)
            throw new ArgumentNullException(nameof(list));

        // 1) Group by CustomerID and check for conflicting Busregnum or Tinum
        var customerGroups = list
            .Where(r => r.CustomerID != null && !string.IsNullOrEmpty(r.CustomerID.Data))
            .GroupBy(r => NormalizeCustomerId(r.CustomerID.Data));

        foreach (var grp in customerGroups)
        {
            var distinctBusregnums = grp
                .Where(r => r.Busregnum != null && !string.IsNullOrEmpty(r.Busregnum.Data))
                .Select(r => r.Busregnum.Data)
                .Distinct()
                .Count();

            var distinctTinums = grp
                .Where(r => r.Tinum != null && !string.IsNullOrEmpty(r.Tinum.Data))
                .Select(r => r.Tinum.Data)
                .Distinct()
                .Count();

            if (distinctBusregnums > 1 || distinctTinums > 1)
            {
                foreach (var rec in grp)
                    rec.CustomerIDBusregnumTinumStatus = "E";
            }
        }

        // 2) Group by Busregnum and check for conflicting CustomerID or Tinum
        var busregGroups = list
            .Where(r => r.Busregnum != null && !string.IsNullOrEmpty(r.Busregnum.Data))
            .GroupBy(r => r.Busregnum.Data);

        foreach (var grp in busregGroups)
        {
            var distinctCustomerIDs = grp
                .Where(r => r.CustomerID != null && !string.IsNullOrEmpty(r.CustomerID.Data))
                .Select(r => NormalizeCustomerId(r.CustomerID.Data))
                .Distinct()
                .Count();

            var distinctTinums = grp
                .Where(r => r.Tinum != null && !string.IsNullOrEmpty(r.Tinum.Data))
                .Select(r => r.Tinum.Data)
                .Distinct()
                .Count();

            if (distinctCustomerIDs > 1 || distinctTinums > 1)
            {
                foreach (var rec in grp)
                    rec.CustomerIDBusregnumTinumStatus = "E";
            }
        }

        // 3) Group by Tinum and check for conflicting CustomerID or Busregnum
        var tinumGroups = list
            .Where(r => r.Tinum != null && !string.IsNullOrEmpty(r.Tinum.Data))
            .GroupBy(r => r.Tinum.Data);

        foreach (var grp in tinumGroups)
        {
            var distinctCustomerIDs = grp
                .Where(r => r.CustomerID != null && !string.IsNullOrEmpty(r.CustomerID.Data))
                .Select(r => NormalizeCustomerId(r.CustomerID.Data))
                .Distinct()
                .Count();

            var distinctBusregnums = grp
                .Where(r => r.Busregnum != null && !string.IsNullOrEmpty(r.Busregnum.Data))
                .Select(r => r.Busregnum.Data)
                .Distinct()
                .Count();

            if (distinctCustomerIDs > 1 || distinctBusregnums > 1)
            {
                foreach (var rec in grp)
                    rec.CustomerIDBusregnumTinumStatus = "E";
            }
        }

        return list;
    }
    List<IndividualContext> DuplicateUser_CustomerIDAndDateOfBirth(List<IndividualContext> _fromExcelFile)
    {
        if (_fromExcelFile == null)
            throw new ArgumentNullException(nameof(_fromExcelFile));

        // 1) Group by normalized CustomerID + NatIDNum
        var groups = _fromExcelFile
            .GroupBy(r => new
            {
                Customer = NormalizeCustomerId(r.CustomerID?.Data),
                Nat = (r.NatIDNum?.Data ?? "").Trim()
            });

        // 2) Identify groups with mismatched DOBs using normalized dates
        var keysWithMismatchedDob = new HashSet<(string, string)>();

        foreach (var group in groups)
        {
            var distinctDobs = new HashSet<string>();
            bool hasMismatch = false;

            foreach (var record in group)
            {
                string dob = NormalizeDate(record.DateOfBirth?.Data);

                if (!distinctDobs.Add(dob))
                    continue;  // Skip if we've already seen this exact DOB

                if (distinctDobs.Count > 1)
                {
                    hasMismatch = true;
                    break;  // No need to check further once we find 2 distinct DOBs
                }
            }

            if (hasMismatch)
            {
                keysWithMismatchedDob.Add((group.Key.Customer, group.Key.Nat));
            }
        }

        // 3) Mark affected records
        foreach (var rec in _fromExcelFile)
        {
            var key = (
                NormalizeCustomerId(rec.CustomerID?.Data),
                (rec.NatIDNum?.Data ?? "").Trim()
            );

            if (keysWithMismatchedDob.Contains(key))
            {
                rec.CusumerIDDateOfBirth = "E";
            }
        }
        var b = _fromExcelFile;

        return _fromExcelFile;
    }

    // ── Issue #12 ─────────────────────────────────────────────────────────────
    // Same ID VALUE (across any of the 7 ID fields) mapped to more than one
    // distinct CustomerID. Cross-column aware: NatIDNum on rec A matching
    // VotersIDNum on rec B is detected and flagged.
    List<IndividualContext> CheckSamePersonalIDDifferentCustomer(List<IndividualContext> list)
    {
        if (list == null) throw new ArgumentNullException(nameof(list));

        // Build cross-column ID value index
        var byIDValue = new Dictionary<string, List<(string CustID, string Field, IndividualContext Rec)>>();

        var idSelectors = new List<(string FieldName, Func<IndividualContext, string?> GetValue)>
        {
            ("NatIDNum",    r => r.NatIDNum?.Data),
            ("VotersIDNum", r => r.VotersIDNum?.Data),
            ("DriverLicNum",r => r.DriverLicNum?.Data),
            ("PassportNum", r => r.PassportNum?.Data),
            ("SSNum",       r => r.SSNum?.Data),
            ("EzwichNum",   r => r.EzwichNum?.Data),
            ("OtherIDNum",  r => r.OtherIDNum?.Data),
        };

        foreach (var rec in list)
        {
            var custId = NormalizeCustomerId(rec.CustomerID?.Data);
            if (string.IsNullOrWhiteSpace(custId)) continue;

            foreach (var (fieldName, getValue) in idSelectors)
            {
                var value = getValue(rec);
                if (!IsValidIDValue(value)) continue;
                var key = value!.Trim().ToUpperInvariant();
                if (!byIDValue.TryGetValue(key, out var bucket))
                { bucket = new List<(string, string, IndividualContext)>(); byIDValue[key] = bucket; }
                bucket.Add((custId, fieldName, rec));
            }
        }

        foreach (var kvp in byIDValue)
        {
            var entries = kvp.Value;
            var distinctCusts = entries.Select(e => e.CustID).Distinct().Count();
            if (distinctCusts > 1)
            {
                var fieldSummary = string.Join("|", entries.Select(e => e.Field).Distinct().OrderBy(f => f));

                // Tiebreaker: same DOB + same canonical name across all CustomerIDs → same person → Warning
                var custGroups = entries.GroupBy(e => e.CustID).Select(g => g.First().Rec).ToList();
                bool samePerson = false;
                if (custGroups.Count > 1)
                {
                    var first      = custGroups[0];
                    var firstDob = (first.DateOfBirth?.Data ?? string.Empty).Trim();

                    samePerson = custGroups.Skip(1).All(other =>
                    {
                        var otherDob = (other.DateOfBirth?.Data ?? string.Empty).Trim();
                        bool dobMatch = !string.IsNullOrWhiteSpace(firstDob) && firstDob == otherDob;
                        bool nameMatch = IsSameNameFull(
                            first.Surname?.Data ?? string.Empty, first.FirstName?.Data ?? string.Empty,
                            other.Surname?.Data ?? string.Empty, other.FirstName?.Data ?? string.Empty);
                        return dobMatch && nameMatch;
                    });
                }

                string flag = samePerson ? $"W:{fieldSummary}" : $"E:{fieldSummary}";
                foreach (var entry in entries)
                    entry.Rec.SamePersonalIDDifferentCustomer = flag;
            }
        }

        return list;
    }

    // ── Issue #14 ─────────────────────────────────────────────────────────────
    // Same CustomerID linked to more than one distinct name cluster across records.
    // Name cluster = normalised Surname + FirstName (trimmed, uppercased).
    // ── CurBal parser ─────────────────────────────────────────────────────────
    // Returns null if blank, non-numeric, or a known placeholder.
    // Used by duplicate resolution to pick the record with the lowest balance.
    decimal? ParseCurBal(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return null;
        var cleaned = raw.Trim().Replace(",", "");
        if (decimal.TryParse(cleaned, out decimal val)) return val;
        return null;
    }

    // ── ID value quality filter ───────────────────────────────────────────────
    // Returns false for values that are too short, all-same-digit, or known
    // placeholders — these would cause false-positive cross-column ID conflicts.
    static readonly HashSet<string> _idPlaceholders = new(StringComparer.OrdinalIgnoreCase)
        { "N/A", "NA", "NONE", "NULL", "NIL", "0", "00000", "-", "NIL", "UNKNOWN", "NOTAPPLICABLE" };

    bool IsValidIDValue(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return false;
        var v = value.Trim();
        if (v.Length < 5) return false;
        if (_idPlaceholders.Contains(v)) return false;
        // All-same-character check (e.g. "0000000", "9999999", "XXXXXXX")
        if (v.Distinct().Count() == 1) return false;
        return true;
    }

    // ── Name normalisation helper ─────────────────────────────────────────────
    // Strips all non-letter characters (hyphens, apostrophes, spaces, periods),
    // uppercases, then sorts tokens alphabetically before joining.
    // This means:
    //   "ADAMU ABDUL-KADIR"  → "ABDULKADIRADAMU"
    //   "ADAMU ABDULKADIR"   → "ABDULKADIRADAMU"  ✓ same
    //   "ADAMU ABDUL KADIR"  → "ABDULKADIRADAMU"  ✓ same
    //   "ADAMU ABDULKADIR MOHAMMED" → "ABDULKADIRAADAMUMOHAMMED" — superset
    // For superset check: shorter canonical is fully contained in longer one.
    // ── Name normalisation helpers ────────────────────────────────────────────
    // Returns letters-only uppercase string for exact/subset matching.
    // "ADAMU ABDUL-KADIR" → "ADAMUABDULKADIR"
    string NormaliseNameForComparison(string surname, string firstName)
    {
        var raw = $"{surname} {firstName}".ToUpperInvariant();
        return new string(raw.Where(char.IsLetter).ToArray());
    }

    // Returns sorted-token canonical for reordering detection.
    // "ASIEDU ASARE" and "ASARE ASIEDU" both → "ASAREASIEDU" after sort
    string NormaliseNameSortedTokens(string surname, string firstName)
    {
        var raw = $"{surname} {firstName}".ToUpperInvariant();
        var tokens = raw.Split(new[] { ' ', '-', '\'', '.', ',' },
                               StringSplitOptions.RemoveEmptyEntries)
                        .Select(t => new string(t.Where(char.IsLetter).ToArray()))
                        .Where(t => t.Length > 0)
                        .OrderBy(t => t);
        return string.Concat(tokens);
    }

    // Returns true if two canonical (letters-only) names match:
    // 1. Exact match
    // 2. Subset — shorter contained in longer (dropped middle name)
    bool IsSameName(string canon1, string canon2)
    {
        if (string.IsNullOrWhiteSpace(canon1) || string.IsNullOrWhiteSpace(canon2)) return false;
        if (canon1 == canon2) return true;
        if (canon2.Contains(canon1) || canon1.Contains(canon2)) return true;
        return false;
    }

    // Full name comparison using both letters-only AND sorted-token methods.
    // Catches: hyphen/space variants, dropped middle names, AND reordered names.
    // "ASIEDU ASARE" vs "ASARE ASIEDU" → sorted tokens both = "ASAREASIEDU" → true
    bool IsSameNameFull(string surname1, string firstName1, string surname2, string firstName2)
    {
        var canon1  = NormaliseNameForComparison(surname1, firstName1);
        var canon2  = NormaliseNameForComparison(surname2, firstName2);
        if (IsSameName(canon1, canon2)) return true;

        var sorted1 = NormaliseNameSortedTokens(surname1, firstName1);
        var sorted2 = NormaliseNameSortedTokens(surname2, firstName2);
        if (sorted1.Length > 0 && sorted2.Length > 0)
        {
            if (sorted1 == sorted2) return true;
            if (sorted2.Contains(sorted1) || sorted1.Contains(sorted2)) return true;
        }
        return false;
    }

    // ── Issue #14 ─────────────────────────────────────────────────────────────
    // Same CustomerID linked to more than one distinct name cluster across records.
    // Uses canonical name comparison + DOB tiebreaker.
    // Rule: if canonical names differ BUT DOB matches → same person, no flag.
    //       if canonical names differ AND DOB differs  → genuine conflict, flag.
    List<IndividualContext> CheckSameCustomerIDDifferentName(List<IndividualContext> list)
    {
        if (list == null) throw new ArgumentNullException(nameof(list));

        var groups = list
            .Where(r => !string.IsNullOrWhiteSpace(r.CustomerID?.Data))
            .GroupBy(r => NormalizeCustomerId(r.CustomerID!.Data));

        foreach (var grp in groups)
        {
            // Get canonical name per record
            var records = grp.ToList();
            bool hasConflict = false;

            for (int i = 0; i < records.Count; i++)
            {
                for (int j = i + 1; j < records.Count; j++)
                {
                    var a = records[i]; var b = records[j];
                    if (!IsSameNameFull(
                            a.Surname?.Data ?? string.Empty, a.FirstName?.Data ?? string.Empty,
                            b.Surname?.Data ?? string.Empty, b.FirstName?.Data ?? string.Empty))
                    {
                        // Names differ — check DOB as tiebreaker
                        var dobA = (a.DateOfBirth?.Data ?? string.Empty).Trim();
                        var dobB = (b.DateOfBirth?.Data ?? string.Empty).Trim();
                        bool dobMatch = !string.IsNullOrWhiteSpace(dobA) &&
                                        !string.IsNullOrWhiteSpace(dobB) &&
                                        dobA == dobB;
                        if (!dobMatch)
                        {
                            hasConflict = true;
                            break;
                        }
                    }
                }
                if (hasConflict) break;
            }

            if (hasConflict)
                foreach (var rec in records)
                    rec.SameCustomerIDDifferentName = "E";
        }

        return list;
    }

    // ── Issue #2 (name mismatch on same facility) ─────────────────────────────
    // Records that share AccNum + CustomerID but have different name clusters.
    // Uses canonical name comparison + DOB tiebreaker (same rules as #14).
    List<IndividualContext> CheckDuplicateNameMismatch(List<IndividualContext> list)
    {
        if (list == null) throw new ArgumentNullException(nameof(list));

        var groups = list
            .Where(r =>
                !string.IsNullOrWhiteSpace(r.CreditFacilityAccNum?.Data) &&
                !string.IsNullOrWhiteSpace(r.CustomerID?.Data))
            .GroupBy(r => (
                AccNum:     NormalizeAccountNumber(r.CreditFacilityAccNum!.Data),
                CustomerID: NormalizeCustomerId(r.CustomerID!.Data)
            ));

        foreach (var grp in groups)
        {
            var records = grp.ToList();
            bool hasConflict = false;

            for (int i = 0; i < records.Count; i++)
            {
                for (int j = i + 1; j < records.Count; j++)
                {
                    var a = records[i]; var b = records[j];
                    var canonA = NormaliseNameForComparison(
                        a.Surname?.Data ?? string.Empty, a.FirstName?.Data ?? string.Empty);
                    var canonB = NormaliseNameForComparison(
                        b.Surname?.Data ?? string.Empty, b.FirstName?.Data ?? string.Empty);

                    if (string.IsNullOrWhiteSpace(canonA) || string.IsNullOrWhiteSpace(canonB))
                        continue;

                    if (!IsSameName(canonA, canonB))
                    {
                        var dobA = (a.DateOfBirth?.Data ?? string.Empty).Trim();
                        var dobB = (b.DateOfBirth?.Data ?? string.Empty).Trim();
                        bool dobMatch = !string.IsNullOrWhiteSpace(dobA) &&
                                        !string.IsNullOrWhiteSpace(dobB) &&
                                        dobA == dobB;
                        if (!dobMatch)
                        {
                            hasConflict = true;
                            break;
                        }
                    }
                }
                if (hasConflict) break;
            }

            if (hasConflict)
                foreach (var rec in records)
                    rec.DuplicateNameMismatch = "E";
        }

        return list;
    }

    // ── Single-pass cross-record check engine (Performance — Sprint 5) ────────
    // Replaces CheckSamePersonalIDDifferentCustomer + CheckSameCustomerIDDifferentName
    // + CheckDuplicateNameMismatch with ONE pass through the list to build all indexes,
    // then applies all checks against those indexes.
    // At 1M records: 4 separate GroupBy passes → 1 build pass + 4 index reads.
    List<IndividualContext> RunAllCrossRecordChecksIND(List<IndividualContext> list)
    {
        if (list == null) throw new ArgumentNullException(nameof(list));

        // ── Build all indexes in a single pass ────────────────────────────────
        // byCustomerID:   normalisedCustomerID → all records with that ID
        // byAccNumCustID: (normAccNum, normCustID) → all records for that facility+customer
        // byIDValue:      any ID value (across ALL 7 ID fields) → list of (customerID, fieldName, record)
        //                 Cross-column: same value in NatIDNum on rec A and VotersIDNum on rec B → flagged
        var byCustomerID   = new Dictionary<string, List<IndividualContext>>();
        var byAccNumCustID = new Dictionary<(string, string), List<IndividualContext>>();
        var byIDValue      = new Dictionary<string, List<(string CustID, string Field, IndividualContext Rec)>>();

        void AddTo<TKey>(Dictionary<TKey, List<IndividualContext>> dict, TKey key, IndividualContext rec)
            where TKey : notnull
        {
            if (!dict.TryGetValue(key, out var bucket)) { bucket = new List<IndividualContext>(); dict[key] = bucket; }
            bucket.Add(rec);
        }

        void IndexIDValue(string? value, string fieldName, string custID, IndividualContext rec)
        {
            if (!IsValidIDValue(value)) return;
            var key = value!.Trim().ToUpperInvariant();
            if (!byIDValue.TryGetValue(key, out var bucket))
            { bucket = new List<(string, string, IndividualContext)>(); byIDValue[key] = bucket; }
            bucket.Add((custID, fieldName, rec));
        }

        foreach (var rec in list)
        {
            var custId = NormalizeCustomerId(rec.CustomerID?.Data);
            var accNum = NormalizeAccountNumber(rec.CreditFacilityAccNum?.Data);

            if (!string.IsNullOrWhiteSpace(custId))
                AddTo(byCustomerID, custId, rec);

            if (!string.IsNullOrWhiteSpace(accNum) && !string.IsNullOrWhiteSpace(custId))
                AddTo(byAccNumCustID, (accNum, custId), rec);

            // Cross-column ID index — all 7 fields indexed by their VALUE
            IndexIDValue(rec.NatIDNum?.Data,     "NatIDNum",     custId, rec);
            IndexIDValue(rec.VotersIDNum?.Data,  "VotersIDNum",  custId, rec);
            IndexIDValue(rec.DriverLicNum?.Data, "DriverLicNum", custId, rec);
            IndexIDValue(rec.PassportNum?.Data,  "PassportNum",  custId, rec);
            IndexIDValue(rec.SSNum?.Data,        "SSNum",        custId, rec);
            IndexIDValue(rec.EzwichNum?.Data,    "EzwichNum",    custId, rec);
            IndexIDValue(rec.OtherIDNum?.Data,   "OtherIDNum",   custId, rec);
        }

        // ── #12: Same ID value → different CustomerIDs (cross-column aware) ──
        foreach (var kvp in byIDValue)
        {
            var entries = kvp.Value;
            var distinctCusts = entries
                .Where(e => !string.IsNullOrWhiteSpace(e.CustID))
                .Select(e => e.CustID)
                .Distinct()
                .Count();

            if (distinctCusts > 1)
            {
                var fieldSummary = string.Join("|", entries
                    .Select(e => e.Field)
                    .Distinct()
                    .OrderBy(f => f));

                // Tiebreaker: check if all distinct CustomerIDs share the same DOB and canonical name
                // If yes → same physical person with different branch IDs → Warning (CLEAN)
                // If no  → genuinely different people sharing an ID → Error (UNLOADABLE)
                var custGroups = entries
                    .GroupBy(e => e.CustID)
                    .Select(g => g.First().Rec)
                    .ToList();

                bool samePerson = false;
                if (custGroups.Count > 1)
                {
                    var first = custGroups[0];
                    var firstDob = (first.DateOfBirth?.Data ?? string.Empty).Trim();

                    samePerson = custGroups.Skip(1).All(other =>
                    {
                        var otherDob = (other.DateOfBirth?.Data ?? string.Empty).Trim();
                        bool dobMatch = !string.IsNullOrWhiteSpace(firstDob) &&
                                        !string.IsNullOrWhiteSpace(otherDob) &&
                                        firstDob == otherDob;
                        bool nameMatch = IsSameNameFull(
                            first.Surname?.Data  ?? string.Empty, first.FirstName?.Data  ?? string.Empty,
                            other.Surname?.Data  ?? string.Empty, other.FirstName?.Data  ?? string.Empty);
                        return dobMatch && nameMatch;
                    });
                }

                // "W" = Warning (same person, different CustomerIDs) → still routes to CLEAN
                // "E" = Error (different people sharing an ID) → routes to UNLOADABLE
                string flag = samePerson ? $"W:{fieldSummary}" : $"E:{fieldSummary}";
                foreach (var entry in entries)
                    entry.Rec.SamePersonalIDDifferentCustomer = flag;
            }
        }

        // ── #14: Same CustomerID → different name clusters ────────────────────
        foreach (var grp in byCustomerID.Values)
        {
            var records = grp.ToList();
            bool hasConflict = false;
            for (int i = 0; i < records.Count && !hasConflict; i++)
            {
                for (int j = i + 1; j < records.Count && !hasConflict; j++)
                {
                    var a = records[i]; var b = records[j];
                    var canonA = NormaliseNameForComparison(
                        a.Surname?.Data ?? string.Empty, a.FirstName?.Data ?? string.Empty);
                    var canonB = NormaliseNameForComparison(
                        b.Surname?.Data ?? string.Empty, b.FirstName?.Data ?? string.Empty);
                    if (string.IsNullOrWhiteSpace(canonA) || string.IsNullOrWhiteSpace(canonB)) continue;
                    if (!IsSameName(canonA, canonB))
                    {
                        var dobA = (a.DateOfBirth?.Data ?? string.Empty).Trim();
                        var dobB = (b.DateOfBirth?.Data ?? string.Empty).Trim();
                        bool dobMatch = !string.IsNullOrWhiteSpace(dobA) &&
                                        !string.IsNullOrWhiteSpace(dobB) && dobA == dobB;
                        if (!dobMatch) hasConflict = true;
                    }
                }
            }
            if (hasConflict)
                foreach (var r in records) r.SameCustomerIDDifferentName = "E";
        }

        // ── #2: Same AccNum+CustomerID → different name clusters ──────────────
        foreach (var grp in byAccNumCustID.Values)
        {
            var records = grp.ToList();
            bool hasConflict = false;
            for (int i = 0; i < records.Count && !hasConflict; i++)
            {
                for (int j = i + 1; j < records.Count && !hasConflict; j++)
                {
                    var a = records[i]; var b = records[j];
                    var canonA = NormaliseNameForComparison(
                        a.Surname?.Data ?? string.Empty, a.FirstName?.Data ?? string.Empty);
                    var canonB = NormaliseNameForComparison(
                        b.Surname?.Data ?? string.Empty, b.FirstName?.Data ?? string.Empty);
                    if (string.IsNullOrWhiteSpace(canonA) || string.IsNullOrWhiteSpace(canonB)) continue;
                    if (!IsSameName(canonA, canonB))
                    {
                        var dobA = (a.DateOfBirth?.Data ?? string.Empty).Trim();
                        var dobB = (b.DateOfBirth?.Data ?? string.Empty).Trim();
                        bool dobMatch = !string.IsNullOrWhiteSpace(dobA) &&
                                        !string.IsNullOrWhiteSpace(dobB) && dobA == dobB;
                        if (!dobMatch) hasConflict = true;
                    }
                }
            }
            if (hasConflict)
                foreach (var r in records) r.DuplicateNameMismatch = "E";
        }

        return list;
    }

    string NormalizeDate(string dob)
    {
        if (string.IsNullOrWhiteSpace(dob))
            return string.Empty;

        string normalized = dob.Trim();

        // Attempt to parse and standardize date format
        if (DateTime.TryParse(normalized, out DateTime date))
        {
            return date.ToString("yyyy-MM-dd");
        }

        return normalized;
    }
    string NormalizeCustomerId(string? value)
    {
        var normalized = RemoveAllWhitespace(value).ToUpperInvariant();
        if (normalized.All(char.IsDigit))
        {
            normalized = normalized.TrimStart('0');
        }
        if (string.IsNullOrEmpty(normalized) && !string.IsNullOrWhiteSpace(value) && RemoveAllWhitespace(value).All(char.IsDigit))
        {
            return "0";
        }
        return normalized;
    }
    string NormalizeAccountNumber(string? value)
    {
        return RemoveAllWhitespace(value).ToUpperInvariant();
    }
    string RemoveAllWhitespace(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }
        return new string(value.Where(c => !char.IsWhiteSpace(c)).ToArray());
    }
    bool HasInternalWhitespace(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return false;
        }
        var trimmed = value.Trim();
        return trimmed.Any(char.IsWhiteSpace);
    }
    bool LooksLikeExponentNotation(string? value)
    {
        var normalized = RemoveAllWhitespace(value);
        if (string.IsNullOrWhiteSpace(normalized))
        {
            return false;
        }
        return System.Text.RegularExpressions.Regex.IsMatch(normalized, @"^[+-]?\d+(\.\d+)?[eE][+-]?\d+$");
    }
    void AddCellError(CellDataAndStatus? cell, string error)
    {
        if (cell == null)
        {
            return;
        }
        cell.Passed = false;
        cell.Errors ??= new List<string>();
        if (!cell.Errors.Contains(error))
        {
            cell.Errors.Add(error);
        }
    }
    void NormalizeAccountAndCustomerFields(CellDataAndStatus? account, CellDataAndStatus? customer, string accountLabel)
    {
        if (account != null)
        {
            if (string.IsNullOrWhiteSpace(account.Data))
            {
                AddCellError(account, $"{accountLabel}: MISSING FACILITY ACCOUNT NUMBER");
            }
            else if (LooksLikeExponentNotation(account.Data))
            {
                AddCellError(account, $"{accountLabel}: INVALID ACCOUNT NUMBER - EXPONENTIATED VALUE DETECTED");
            }
            else
            {
                if (HasInternalWhitespace(account.Data))
                {
                    account.Data = NormalizeAccountNumber(account.Data);
                }
                else
                {
                    account.Data = account.Data?.Trim();
                }
            }
        }

        if (customer != null)
        {
            if (LooksLikeExponentNotation(customer.Data))
            {
                AddCellError(customer, "CUSTOMERID: INVALID CUSTOMER ID - EXPONENTIATED VALUE DETECTED");
            }
            else
            {
                customer.Data = NormalizeCustomerId(customer.Data);
            }
        }

        if (account != null && customer != null &&
            !string.IsNullOrWhiteSpace(account.Data) &&
            !string.IsNullOrWhiteSpace(customer.Data) &&
            NormalizeAccountNumber(account.Data) == NormalizeCustomerId(customer.Data))
        {
            AddCellError(account, $"{accountLabel}: FACILITY ACCOUNT NUMBER CANNOT BE THE SAME AS CUSTOMERID");
            AddCellError(customer, "CUSTOMERID: CUSTOMERID CANNOT BE THE SAME AS FACILITY ACCOUNT NUMBER");
        }
    }
    (List<IndividualContext> allRecords, List<IndividualContext> duplicatesInd, string correctDateOfBirth, string dobIssues, string matchdata, string newdata, string duplicatescount) REF_MainMatcherTransformerInd_Clean_IND(List<IndividualRef> fromDatabase, List<IndividualContext> _fromExcelFile, bool handleDuplicates = true)
    {
        // Initialize lists to store processed Excel records and duplicates
        List<IndividualContext> processedExcelRecords = new List<IndividualContext>();
        List<IndividualContext> duplicatesList = new List<IndividualContext>();

        // Preprocess the Excel records to flag potential duplicate Date of Birth issues
        var fromExcelFile = AssignDuplicateDoBIssues(_fromExcelFile);

        if (handleDuplicates)
        {
            // Dictionary tracks the BEST record seen so far per key (lowest CurBal wins).
            // Key: (AccNum, CustomerID, DisbursementDate)
            // Value: the record currently kept as the clean version
            var seenKeys = new Dictionary<(string, string, string?), IndividualContext>();
            processedExcelRecords = new List<IndividualContext>();

            foreach (var record in fromExcelFile)
            {
                var key = (
                    NormalizeAccountNumber(record.CreditFacilityAccNum?.Data),
                    NormalizeCustomerId(record.CustomerID?.Data),
                    record.DisbursementDate?.Data
                );

                // Overdraft facilities legitimately appear multiple times — exempt from duplicate rule
                bool isOverdraft = (record.CreditFacilityType?.Data ?? string.Empty)
                    .Trim().ToUpperInvariant() == "V";

                if (seenKeys.TryGetValue(key, out var existing) &&
                    string.IsNullOrWhiteSpace(record.DuplicateDoBIssues) && !isOverdraft)
                {
                    // Duplicate found — compare CurBal to decide which to keep
                    decimal? incomingBal = ParseCurBal(record.CurBal?.Data);
                    decimal? existingBal = ParseCurBal(existing.CurBal?.Data);

                    bool keepIncoming;
                    if (incomingBal.HasValue && existingBal.HasValue)
                        keepIncoming = incomingBal.Value < existingBal.Value;  // lower wins
                    else if (incomingBal.HasValue && !existingBal.HasValue)
                        keepIncoming = true;   // known value beats blank
                    else
                        keepIncoming = false;  // existing wins if incoming is blank or equal

                    if (keepIncoming)
                    {
                        // Swap: existing goes to duplicate sheet, incoming becomes the kept record
                        duplicatesList.Add(existing);
                        seenKeys[key] = record;
                        // Replace existing in processedExcelRecords
                        var idx = processedExcelRecords.IndexOf(existing);
                        if (idx >= 0) processedExcelRecords[idx] = record;
                        else processedExcelRecords.Add(record);
                    }
                    else
                    {
                        duplicatesList.Add(record); // incoming loses — goes to duplicate sheet
                    }
                }
                else
                {
                    seenKeys[key] = record;
                    processedExcelRecords.Add(record);
                }
            }
        }
        else
        {
            processedExcelRecords = fromExcelFile.ToList();
        }

        // Create a dictionary from database records for quick lookup by (CreditFacilityAccNum, CustomerID)
        var databaseDict = new Dictionary<(string, string), IndividualRef>();
        foreach (var dbRecord in fromDatabase)
        {
            var key = (NormalizeAccountNumber(dbRecord.CreditFacilityAccNum), NormalizeCustomerId(dbRecord.CustomerID));
            databaseDict[key] = dbRecord;
        }

        // Initialize counters for various types of matches/issues
        int __correctDateOfBirth = 0;
        int __dobIssues = 0;
        int __matchdata = 0;
        int __newdata = 0;
        int __burscount = 0; // Count of disbursement date mismatch

        // Compare each processed Excel record against database entries
        foreach (var excelRecord in processedExcelRecords)
        {
            var creditFacilityAccNum = NormalizeAccountNumber(excelRecord.CreditFacilityAccNum?.Data);
            var customerID = NormalizeCustomerId(excelRecord.CustomerID?.Data);
            var disbursementDate = excelRecord.DisbursementDate?.Data;

            var key = (creditFacilityAccNum, customerID);

            if (databaseDict.TryGetValue(key, out var dbRecord))
            {
                // Found matching record in the database
                var excelDob = excelRecord.DateOfBirth?.Data;
                __matchdata++;

                // ── Sprint 10: Store reference canonical name for validation pass ──
                // If the reference has name data, record it so the validation pass
                // can trust names that were accepted in the previous clean.
                if (!string.IsNullOrWhiteSpace(dbRecord.Surname) || !string.IsNullOrWhiteSpace(dbRecord.FirstName))
                {
                    excelRecord.ReferenceCanonicalName =
                        NormaliseNameSortedTokens(
                            dbRecord.Surname  ?? string.Empty,
                            dbRecord.FirstName ?? string.Empty);
                }

                // Check if DisbursementDate matches
                if (dbRecord.DisbursementDate != disbursementDate)
                {
                    excelRecord.DisburStatus = " THE DISBURSEMENT DATE DOES NOT MATCH THE PREVIOUS SUBMISSION ";
                    __burscount++;
                }
                else if (dbRecord.DateOfBirth == excelDob)
                {
                    __correctDateOfBirth++; // DOB matches
                }
                else
                {
                    excelRecord.Status = "DOB"; // Flag DOB mismatch
                    __dobIssues++;
                }
            }
            else
            {
                // No match found - it's new data
                __newdata++;
            }
        }

        // Return the final processed results
        return (
            processedExcelRecords,
            duplicatesList,
            __correctDateOfBirth.ToString(),
            __dobIssues.ToString(),
            __matchdata.ToString(),
            __newdata.ToString(),
            duplicatesList.Count.ToString()
        );
    }
    List<IndividualContext> AssignDuplicateDoBIssues(List<IndividualContext> individuals)
    {
        // Group records by CreditFacilityAccNum and CustomerID
        var groups = individuals.GroupBy(i => new
        {
            Credit = NormalizeAccountNumber(i.CreditFacilityAccNum?.Data),
            Customer = NormalizeCustomerId(i.CustomerID?.Data),
        });

        // For each group
        foreach (var group in groups)
        {
            // If more than one record exists for the same key
            if (group.Count() > 1)
            {
                // Extract all DateOfBirth values
                var dobValues = group.Select(i => i.DateOfBirth?.Data);

                // Extract all Disbursement date values
                var disValues = group.Select(i => i.DisbursementDate?.Data);

                // Check if DOBs differ
                if (dobValues.Distinct().Count() > 1)
                {
                    // Mark all records in this group with duplicate DOB issue
                    foreach (var individual in group)
                    {
                        individual.DuplicateDoBIssues = "UNL";
                    }
                }
                // Check if Disbursment date differ
                if (disValues.Distinct().Count() > 1)
                {
                    // Mark all records in this group with duplicate DOB issue
                    foreach (var individual in group)
                    {
                        individual.DisbursementDateMisMatch = "UNL";
                    }
                }

            }
        }

        // Return updated list
        return individuals;
    }
