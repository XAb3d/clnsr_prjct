    void ValidateHeaders(List<string> expectedHeaders, List<string> actualHeaders, SpreadSheetStatusContext spreadSheetStatus)
    {
        int maxLength = Math.Min(expectedHeaders.Count, actualHeaders.Count);
        for (int i = 0; i < maxLength; i++)
        {
            var errorsPair = new ErrorsPairs(expectedHeaders[i], actualHeaders[i]);
            if (i == 17 && (actualHeaders[i] == "dateofbrith" || actualHeaders[i] == "dob1")) //17
            {
                errorsPair = null;
            }
            if (i == 2 && actualHeaders[i] == "facilityaccnum") //2
            {
                errorsPair = null;
            }

            if (i == 11 && actualHeaders[i] == "otherid") //11
            {
                errorsPair = null;
            }
            if (i == 22 && actualHeaders[i] == "prevname") //22
            {
                errorsPair = null;
            }
            if (i == 70 && actualHeaders[i] == "facilityter") //70
            {
                errorsPair = null;
            }
            //TRACK COLLUMNS // It start from index 0
            if (!string.Equals(expectedHeaders[i], actualHeaders[i], StringComparison.OrdinalIgnoreCase) && errorsPair != null)
            {
                spreadSheetStatus.InvalidHeaders.Add(errorsPair);
            }
        }
    }
    async Task<byte[]> SaveToExcelAsync<T>(List<T> context, List<T> context_duplicate)
    {
        return await Task.Run(() =>
        {

            using (var wb = new XLWorkbook())
            {
                var ws = wb.Worksheets.Add("CLEAN");
                var wsu = wb.Worksheets.Add("UNL");
                var wsd = wb.Worksheets.Add("DUPLICATE");

                if (typeof(T) == typeof(BusinessContext))
                {
                    WriteHeaders(ws, wsu, wsd, SpreadSheetHeadersData.Business, 159);
                    WriteData(context.OfType<BusinessContext>().ToList(), context_duplicate.OfType<BusinessContext>().ToList(), ws, wsu, wsd);
                }
                else if (typeof(T) == typeof(IndividualContext))
                {
                    WriteHeaders(ws, wsu, wsd, SpreadSheetHeadersData.Individual, 179);
                    // Add WARNING column header at col 180 for IND sheets only
                    ws.Cell(1, 180).Value  = "--------------- Warnings ---------------";
                    wsu.Cell(1, 180).Value = "--------------- Warnings ---------------";
                    wsd.Cell(1, 180).Value = "--------------- Warnings ---------------";
                    WriteData(context.OfType<IndividualContext>().ToList(), context_duplicate.OfType<IndividualContext>().ToList(), ws, wsu, wsd);
                }
                else if (typeof(T) == typeof(BusinessContextDud))
                {
                    WriteHeaders(ws, wsu, wsd, SpreadSheetHeadersData.BusinessDud, 47);
                    WriteData(context.OfType<BusinessContextDud>().ToList(), context_duplicate.OfType<BusinessContextDud>().ToList(), ws, wsu, wsd);
                }
                else if (typeof(T) == typeof(IndividualContextDud))
                {
                    WriteHeaders(ws, wsu, wsd, SpreadSheetHeadersData.IndividualDud, 75);
                    WriteData(context.OfType<IndividualContextDud>().ToList(), context_duplicate.OfType<IndividualContextDud>().ToList(), ws, wsu, wsd);
                }

                using var stream = new MemoryStream();
                wb.SaveAs(stream);
                return stream.ToArray();
            }
        });
    }
    void WriteHeaders(IXLWorksheet ws, IXLWorksheet wsu, IXLWorksheet wsd, List<string> headers, int errorIndex)
    {
        for (int i = 0; i < headers.Count; i++)
        {
            ws.Cell(1, i + 1).Value = headers[i];
            wsu.Cell(1, i + 1).Value = headers[i];
            wsd.Cell(1, i + 1).Value = headers[i];
        }
        wsu.Cell(1, errorIndex).Value = "--------------- Errors ---------------";
    }
    void WriteData<T>(List<T> rows, List<T> dup_rows, IXLWorksheet ws, IXLWorksheet wsu, IXLWorksheet wsd) where T : class
    {
        int correctDataCellIndex = 2;
        int correctCellDuplicate = 2;
        int wrongDataCellIndex = 2;
        bool iSCleaned = false;

        foreach (var row in rows)
        {
            iSCleaned = ISCleaned(row);
            if (iSCleaned)
            {
                WriteRow(ws, row, ref iSCleaned, ref correctDataCellIndex);
            }
            else
            {
                WriteRow(wsu, row, ref iSCleaned, ref wrongDataCellIndex);
            }
        }
        foreach (var dup_row in dup_rows)
        {
            WriteRow_dup(wsd, dup_row, ref correctCellDuplicate);
        }
        ws.Columns().AdjustToContents();
        wsu.Columns().AdjustToContents();
        wsd.Columns().AdjustToContents();
    }
