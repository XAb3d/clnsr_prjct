    async Task DownloadExcelDataStream(byte[] excelData, string targetFilePath)
    {
        string SecuredFileNameOrRawFileName = targetFilePath!;
        if (PRINT_EXCEL_WITH_SECURED_NAME)
        {
            SecuredFileNameOrRawFileName = Path.GetFileName(targetFilePath!);
        }
        else { SecuredFileNameOrRawFileName = GetFileNameFromFile(targetFilePath!); }
        // Trigger download using JavaScript Interop
        await JS.InvokeVoidAsync("downloadFile", SecuredFileNameOrRawFileName, excelData, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
        File.Delete(FullExcelDataFilePath!);
    }
