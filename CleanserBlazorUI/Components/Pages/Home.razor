            var filePath = Path.Combine(Environment.WebRootPath, "temp");
            var fullFilePath = Path.Combine(filePath, "appSettings.txt");
            // Write the data to the file
            File.WriteAllLines(fullFilePath, data);
            return File.ReadAllLines(fullFilePath);
        }
        catch (Exception)
        {
        }
        return new string[1];
    }
