        isLoading = true;
        GetErrorsPairsList.Clear();
        int rejectedFiles = 0;

        foreach (var browserFile in e.GetMultipleFiles(MAX_FILES))
        {
            spreadsheetFileAndChipColor.Clear();
            try
            {
                var extension = Path.GetExtension(browserFile.Name);
                if (browserFile != null && extension == ".xlsx" && await CheckFileNamesAllowed(browserFile))
                {
                    spreadsheetFileAndChipColor.Add(new SpreadsheetFileAndChipColor { SpreadsheetFile = browserFile, SpreadsheetFileColor = Color.Primary, IsPassed = true });
                }
                else
                {
                    spreadsheetFileAndChipColor.Add(new SpreadsheetFileAndChipColor { SpreadsheetFile = browserFile, SpreadsheetFileColor = Color.Error, IsPassed = false });
                }
            }
            catch (Exception)
            {
            }

        }
        if (numberofFileswithoutreference > 0)
        {
            ToggleCleaningViewOrRefView(1);
        }
        else
