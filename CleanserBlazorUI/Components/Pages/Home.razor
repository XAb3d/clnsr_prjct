            var spreadSheetStatus = new SpreadSheetStatusContext();

            using (var wb = new XLWorkbook(fileResult))
            {
                // Assumes that the data is in the first worksheet.
                var ws = wb.Worksheet(1);

                // Get all used rows. Alternatively, use ws.Rows() if you want every row.
                var rows = ws.RowsUsed().ToList();
                var headerRow = ws.Row(1);
