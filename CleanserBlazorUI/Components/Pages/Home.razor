@page "/"
@rendermode InteractiveServer
@using CleanserBlazorUI.DevelopmentFolder
@using ICleanserBlazorUI.Interface
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@* @implements IDisposable *@
@inject ISnackbar Snackbar
@inject DataManagementService DataManagementService
@inject UserManager<ApplicationUser> UserManager
@inject ICustomEmailSender EmailSender
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IdentityRedirectManager RedirectManager
@inject ILogger<Home> Logger


@attribute [Authorize]
<div>
    <div style="width:100%; background: #001D23">
        <MudAlert Class="@AlertSeverityVisible" Severity="@AlertSeverity">@AlertSeverityMessage</MudAlert>
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Buffer="true" Class="@progressIsVisible" Style="margin-top: 10px; margin-bottom: 0px;" />
        <MudExpansionPanels Elevation="24">
            @foreach (var item in TopExpandPanelsContent!)
            {
                <MudExpansionPanel Text="@item.Title" Expanded="@OpenExpandedPanel" ExpandedChanged="() => OnPanelExpandedChanged(item.IdShortName)" style="background: #001D23">
                    <MudStack Style="width: 100%">
                        <style>
                            /* Dark theme styles */
                            .dropzone {
                                width: 100%;
                                padding: 40px;
                                border: 2px dashed #40953e; /* Blue accent */
                                background-color: transparent; /* Dark background */
                                color: #ccc; /* Light text */
                                text-align: center;
                                cursor: pointer;
                                transition: background-color 0.3s ease, border-color 0.3s ease;
                                position: relative;
                                display: flex;
                                align-items: center;
                                justify-content: center;
                                border-radius: 8px;
                            }

                                .dropzone:hover {
                                    background-color: transparent; /* Slightly lighter on hover */
                                    border-color: #40953e;
                                }

                                .dropzone.dragover {
                                    background-color: #333; /* Subtle highlight */
                                    border-color: #40953e; /* Bright blue highlight */
                                    box-shadow: 0 0 10px rgba(0, 29, 35, 0.3);
                                }

                                /* Hide the file input but keep it functional */
                                .dropzone input[type="file"] {
                                    position: absolute;
                                    width: 100%;
                                    height: 100%;
                                    opacity: 0;
                                    cursor: pointer;
                                }

                            /* Uploaded file list */
                            .file-list {
                                margin-top: 10px;
                                padding: 0;
                                list-style: none;
                            }

                                .file-list li {
                                    padding: 8px;
                                    background: #292929;
                                    border: 1px solid #444;
                                    border-radius: 4px;
                                    margin-bottom: 5px;
                                    color: #ddd;
                                }
                        </style>

                        <div @ref="DropZone" class="dropzone">
                            <p>Drag & drop Excel files here or <strong>click to select</strong></p>
                            <InputFile OnChange="REF_FileUpload" multiple accept="@ACCEPTED_FILETYPE" />
                        </div>

                        @if (isLoading)
                        {
                            <p>Uploading...</p>
                        }
                        else
                        {
                            <ul>
                                @foreach (var file in spreadsheetFileAndChipColor)
                                {
                                    <MudChip T="String" IconColor="Color.Error" Color="file.SpreadsheetFileColor" OnClose="() => RemoveFile(file)">@file.SpreadsheetFile.Name</MudChip>
                                }
                            </ul>
                        }
                        @if (!string.IsNullOrEmpty(ErrorMessage))
                        {
                            <div>@ErrorMessage</div>
                        }
                    </MudStack>
                    <MudPaper Class="d-flex flex-row py-3 px-2" Elevation="24" Style="@($"color:{Colors.LightGreen.Accent3}; background:{Colors.BlueGray.Darken4};")">
                        <MudButtonGroup Color="Color.Primary" Variant="Variant.Text" DropShadow="true">
                            <MudButton OnClick="() => ToggleCleaningViewOrRefView(1)">CLEANING A FILE</MudButton>
                            <MudButton OnClick="() => ToggleCleaningViewOrRefView(2)">REFERENCE A FILE</MudButton>
                        </MudButtonGroup>
                    </MudPaper>
                    <MudDivider Class="mb-3"></MudDivider>
                    <div class="@cleaningView">
                        <MudPaper class="d-flex flex-row py-1" Elevation="0">
                            <MudButton Variant="Variant.Text" Color="Color.Inherit">DUPLICATE RECORD: @duplicateCount</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Inherit">NEW RECORD: @newdata</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Inherit">MATCH RECORD: @matchdata</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Inherit">DOBISSUES: @dobIssues</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Inherit">CORRECT DOB: @correctDateOfBirth</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Inherit">TOTAL: @readCounting</MudButton>
                            <MudSpacer></MudSpacer>
                            <MudCheckBox Class="my-1 mx-1" style="padding-right: 10px;" Color="Color.Primary" @bind-Value="CleanOnlyOrCleanAndReference" Label="CLEAN ONLY"></MudCheckBox>
                            <MudButton Class="my-1 mx-1" Variant="Variant.Filled" Color="Color.Error" OnClick="ClearSeletedFiles">Reload Cleanser</MudButton>
                            @* <MudButton Class="my-1 mx-1" Variant="Variant.Filled" Color="Color.Primary" OnClick="() => RunCleanser(item.Id)"> Run Cleanser</MudButton> *@

                            <MudButton Class="my-1 mx-1" Variant="Variant.Filled" Color="Color.Primary" Disabled="@_processing" OnClick="() => RunCleanser(item.Id)">
                                @if (_processing)
                                {
                                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                    <MudText Class="ms-2">Cleaning</MudText>
                                }
                                else
                                {
                                    <MudText>Run Cleanser</MudText>
                                }
                            </MudButton>
                        </MudPaper>
                    </div>

                    <div class="@referenceView">
                        <MudDivider Class="mb-3"></MudDivider>
                        <MudPaper Class="d-flex flex-row" Elevation="0">
                            <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="REF_ClearSeletedFiles">Reload Cleanser</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Warning" OnClick="REF_InsertThisAsLatesReference">Insert reference(s)</MudButton>
                            <MudSpacer></MudSpacer>
                            <MudButton Variant="Variant.Text" Color="Color.Inherit">DUPLICATE RECORD: @duplicateCount</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Inherit">NEW RECORD: @newdata</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Inherit">MATCH RECORD: @matchdata</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Inherit">DOBISSUES: @dobIssues</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Inherit">CORRECT DOB: @correctDateOfBirth</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Inherit">TOTAL: @readCounting</MudButton>
                        </MudPaper>
                    </div>



                </MudExpansionPanel>
            }
        </MudExpansionPanels>

    </div>
    @*  <>Result from file upload</> *@
    @if (GetErrorsPairsList.Count > 0)
    {
        <div style="width:100%;">
            <MudPaper Class="p-0 m-0" Elevation="0" MinHeight="300">
                <MudTabs AlwaysShowScrollButtons="false" Outlined="true" Position="@Position.Top" Rounded="true" Border="true" ApplyEffectsToContainer="true" Class="mt-5" PanelClass="pa-6">
                    @*  <>--------------Failed 1----------------</> *@

                    <MudTabPanel Text="INVALID HEADERS" BadgeData="@numberOffailedCount" BadgeColor="Color.Error" Class="m-0 p-0">
                        <MudExpansionPanels>
                            @if (GetErrorsPairsList != null && GetErrorsPairsList.Any() && GetAllFailedFileLenght() != null && GetAllFailedFileLenght().Count == GetErrorsPairsList.Count)
                            {
                                for (int i = 0; i < GetErrorsPairsList.Count; i++)
                                {
                                    var errorsGroup = GetErrorsPairsList[i];
                                    var panelTitle = GetAllFailedFileLenght()[i];

                                    <MudExpansionPanel Text="@panelTitle">
                                        <MudTable Items="errorsGroup" Bordered="false" Striped="false" Elevation="0">
                                            <HeaderContent>
                                                <MudTh>Expected Header</MudTh>
                                                <MudTh>Uploaded Header</MudTh>
                                            </HeaderContent>
                                            <RowTemplate>
                                                <MudTd>@context.ExpectedHeader</MudTd>
                                                <MudTd><MudText Color="Color.Error">@context.UploadedHeader</MudText></MudTd>
                                            </RowTemplate>
                                        </MudTable>
                                    </MudExpansionPanel>
                                }
                            }
                            else
                            {
                                <MudExpansionPanel Text="No Data">
                                    <p>No errors to display.</p>
                                </MudExpansionPanel>
                            }
                        </MudExpansionPanels>

                    </MudTabPanel>
                </MudTabs>
            </MudPaper>
        </div>
    }
</div>





