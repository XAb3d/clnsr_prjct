                    //ReadFromExcel(destinationStream, out ExcelDataRecieved, out SpreadSheetStatus);
                    CleanserBlazorUI.DevelopmentFolder.ExtractSpreadSheetHeader.HeaderExtracter(destinationStream);
                    var numberOfHeaderErrors = SpreadSheetStatus.InvalidHeaders.Count;
