                    var numberOfHeaderErrors = SpreadSheetStatus.InvalidHeaders.Count;
                    if (numberOfHeaderErrors >= 1)
                    {
                        AlertSeverityVisible = "d-block";
                        AlertSeverityMessage = "Warning: The uploaded spreadsheet(s) does not contains the expected headers";
                        AlertSeverity = MudBlazor.Severity.Warning;
                        StateHasChanged();
                        failedRecord.Add(SingleSheetRecords);
                        fullFailedFilesPaths.Add(FullExcelDataFilePath);
                        GetErrorsPairs = new List<ErrorsPairs>();
                        GetErrorsPairs = SpreadSheetStatus.InvalidHeaders;
                        GetErrorsPairsList.Add(GetErrorsPairs);
                    }
                    else
                    {
                        AlertSeverityMessage = "Success: The uploaded spreadsheet contains the expected headers";
                        AlertSeverity = MudBlazor.Severity.Success;
                        AlertSeverityVisible = "d-block";

                        // var RefData = await DataManagementService.GETReferenceData_BUS(filename);
                        // isSubscriber_X_or_Y = await DataManagementService.GetSubscribeX_or_Y(filename);
                        // var (mainMatcherTransformer, _duplicatesInd, _correctDateOfBirth, _dobIssues, _matchdata, _newdata, _duplicateCount) = REF_MainMatcherTransformerInd_Clean_BUS(RefData, ExcelDataRecieved);

                        // correctDateOfBirth = _correctDateOfBirth.ToString();
                        // dobIssues = _dobIssues.ToString();
                        // matchdata = _matchdata.ToString();
                        // newdata = _newdata.ToString();
                        // duplicateCount = _duplicateCount.ToString();
                        // if (CleanOnlyOrCleanAndReference == false)
                        // {
                        //     await DataManagementService.SaveExcelDataToDatabaseBus(ExcelDataRecieved, filename);
                        // }
                        byte[] ExcelDataTobeDownloaded = await SaveToExcelAsync(ExcelDataRecieved, new List<BusinessContextDud>());
                        await DownloadExcelDataStream(ExcelDataTobeDownloaded, FullExcelDataFilePath);
                        File.Delete(FullExcelDataFilePath!);
                        StateHasChanged();
                        ExcelDataRecieved.Clear();
                        ExcelDataRecieved = null;
                        AlertSeverityVisible = "d-none";
                    }
                }

            }
            catch (Exception)
            {
            }
            return CleaningStatus.CompletedWithUnknownErrors;
        }
        return new CleaningStatus();
    }
