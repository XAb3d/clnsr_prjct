    async Task<CleaningStatus> REF_GetSpreadsheetData(IBrowserFile browserFile, int id)
    {
        StreamHelper streamHelper = new();
        if (id == 1)
        {
            try
            {
                // Resetting variables
                FileName = string.Empty; FileSize = default; FileSizeInString = string.Empty; string extension = string.Empty;
