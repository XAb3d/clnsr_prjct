@page "/refdata"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@implements IDisposable
@inject ISnackbar Snackbar
@inject DataManagementService DataManagementService


@* @attribute [Authorize]
@* <p>Your email is: @authState.User.FindFirst(System.Security.Claims.ClaimTypes.Email).Value</p>  *@
@*@attribute [Authorize(Policy = "PasswordChanged")] *@

<style>
    .timer-container {
    text-align: center;
    margin: 20px;
    /* padding: 20px; */
    border: 1px solid #ddd;
    border-radius: 8px;
    }

    .timer-controls {
    margin-top: 15px;
    }

    .btn {
    margin: 0 5px;
    padding: 8px 16px;
    }
</style>
<div Width="100%" Style="background-color:#000000;min-height:100%;overflow: hidden;">

    <div style="width:100%;">
        <MudAlert Class="@AlertSeverityVisible" Severity="@AlertSeverity">@AlertSeverityMessage</MudAlert>
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Buffer="true" Class="@progressIsVisible" Style="margin-top: 10px; margin-bottom: 0px;" />
        <MudExpansionPanels Dense="false">
            @foreach (var item in TopExpandPanelsContent!)
            {
                <MudExpansionPanel Text="@item.Title" Expanded="@closePanels" ExpandedChanged="() => REF_OnPanelExpandedChanged(item.IdShortName)" Icon="@Icons.Material.Filled.JoinFull">
                    <MudStack Style="width: 100%">
                        <style>
                            /* Dark theme styles */
                            .dropzone {
                            width: 100%;
                            padding: 40px;
                            border: 2px dashed #4a90e2; /* Blue accent */
                            background-color: transparent; /* Dark background */
                            color: #ccc; /* Light text */
                            text-align: center;
                            cursor: pointer;
                            transition: background-color 0.3s ease, border-color 0.3s ease;
                            position: relative;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            border-radius: 8px;
                            }

                            .dropzone:hover {
                            background-color: transparent; /* Slightly lighter on hover */
                            border-color: #5a9ded;
                            }

                            .dropzone.dragover {
                            background-color: #333; /* Subtle highlight */
                            border-color: #72b4ff; /* Bright blue highlight */
                            box-shadow: 0 0 10px rgba(114, 180, 255, 0.3);
                            }

                            /* Hide the file input but keep it functional */
                            .dropzone input[type="file"] {
                            position: absolute;
                            width: 100%;
                            height: 100%;
                            opacity: 0;
                            cursor: pointer;
                            }

                            /* Uploaded file list */
                            .file-list {
                            margin-top: 10px;
                            padding: 0;
                            list-style: none;
                            }

                            .file-list li {
                            padding: 8px;
                            background: #292929;
                            border: 1px solid #444;
                            border-radius: 4px;
                            margin-bottom: 5px;
                            color: #ddd;
                            }
                        </style>

                        <div @ref="DropZone" class="dropzone">
                            <p>Drag & drop Excel files here or <strong>click to select</strong></p>
                            <InputFile OnChange="REF_FileUpload" multiple accept="@ACCEPTED_FILETYPE" />
                        </div>

                        @if (isLoading)
                        {
                            <p>Uploading...</p>
                        }
                        else
                        {
                            <ul>
                                @foreach (var file in spreadsheetFileAndChipColor)
                                {
                                    <MudChip T="String" IconColor="Color.Error" Color="file.SpreadsheetFileColor" OnClose="() => REF_RemoveFile(file)">@file.SpreadsheetFile.Name</MudChip>
                                }
                            </ul>
                        }
                        @if (!string.IsNullOrEmpty(ErrorMessage))
                        {
                            <div>@ErrorMessage</div>
                        }
                    </MudStack>
                    <MudDivider Class="mb-3"></MudDivider>
                    <MudPaper Class="d-flex flex-row" Elevation="0">
                        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="REF_ClearSeletedFiles">Reload Cleanser</MudButton>
                        <MudButton class="@showorHideReferenceButton" Variant="Variant.Text" Color="Color.Success" OnClick="REF_StartReferencing"> Start Referencing</MudButton>
                        <MudButton class="@showorHideInsertReferenceButton" Variant="Variant.Text" Color="Color.Warning" OnClick="REF_InsertThisAsLatesReference">Insert reference(s)</MudButton>
                        <MudSpacer></MudSpacer>
                        <MudButton StartIcon="@Icons.Custom.FileFormats.FileDocument" Variant="Variant.Text" Color="Color.Inherit">RECORDS LOADED: @readCounting</MudButton>
                        <MudButton StartIcon="@Icons.Custom.FileFormats.FileDocument" Variant="Variant.Text" Color="Color.Inherit">RECORDS PROCESSED: @writeCounting</MudButton>
                    </MudPaper>
                </MudExpansionPanel>
            }
        </MudExpansionPanels>
    </div>






    @*  <>Result from file upload</> *@
    <div style="width:100%;">
        <MudPaper Class="p-0 m-0" Elevation="0" MinHeight="300">
            <MudTabs AlwaysShowScrollButtons="false" Outlined="true" Position="@Position.Top" Rounded="true" Border="true" ApplyEffectsToContainer="true" Class="mt-5" PanelClass="pa-6">
                @*  <>--------------Failed 1----------------</> *@
                @if (GetErrorsPairsList.Count > 0)
                {
                    <MudTabPanel Text="INVALID HEADERS" BadgeData="@numberOffailedCount" BadgeColor="Color.Error" Class="m-0 p-0">
                        <MudExpansionPanels>
                            @if (GetErrorsPairsList != null && GetErrorsPairsList.Any() && REF_GetAllFailedFileLenght() != null && REF_GetAllFailedFileLenght().Count == GetErrorsPairsList.Count)
                            {
                                for (int i = 0; i < GetErrorsPairsList.Count; i++)
                                {
                                    var errorsGroup = GetErrorsPairsList[i];
                                    var panelTitle = REF_GetAllFailedFileLenght()[i];

                                    <MudExpansionPanel Text="@panelTitle">
                                        <MudTable Items="errorsGroup" Bordered="false" Striped="false" Elevation="0">
                                            <HeaderContent>
                                                <MudTh>Expected Header</MudTh>
                                                <MudTh>Uploaded Header</MudTh>
                                            </HeaderContent>
                                            <RowTemplate>
                                                <MudTd>@context.ExpectedHeader</MudTd>
                                                <MudTd><MudText Color="Color.Error">@context.UploadedHeader</MudText></MudTd>
                                            </RowTemplate>
                                        </MudTable>
                                    </MudExpansionPanel>
                                }
                            }
                            else
                            {
                                <MudExpansionPanel Text="No Data">
                                    <p>No errors to display.</p>
                                </MudExpansionPanel>
                            }
                        </MudExpansionPanels>

                    </MudTabPanel>
                }

                @*  <>--------------Passed 2----------------</> *@
                <MudTabPanel Text="">
                    <MudPaper style="display: flex;flex-direction: column;justify-content: center;">
                        <MudPaper Elevation="0">
                            @if (fullPastFilesPaths != null)
                            {
                                foreach (var item in fullPastFilesPaths)
                                {
                                    <MudPaper Elevation="0" Class="my-2 py-y" Style="background-color: #36363F">
                                        <MudButton Variant="Variant.Text" StartIcon="@Icons.Custom.FileFormats.FileDocument">@REF_GetFileNameFromFile(item)</MudButton>
                                        <MudDivider />
                                    </MudPaper>
                                }
                            }
                        </MudPaper>
                    </MudPaper>
                </MudTabPanel>
            </MudTabs>
        </MudPaper>
    </div>
</div>

