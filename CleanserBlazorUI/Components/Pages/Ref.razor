    protected override async Task OnInitializedAsync()
    {
        allowedFileNames = await DataManagementService.GetSubscriberUserInfosShotCode();
        TopExpandPanelsContent = dataCleaningType.GetDataReferencings();
        progressIsVisible = "d-none";
        AlertSeverityVisible = "d-none";
        _timer = new System.Timers.Timer(5000);
        _timer.Elapsed += OnTimerElapsed;
        _timer.AutoReset = true;
    }
    private async void OnTimerElapsed(object sender, System.Timers.ElapsedEventArgs e)
    {
        _elapsedTime = _elapsedTime.Add(TimeSpan.FromSeconds(5));
        writeCounting = writeCounting;
        readCounting = readCounting;
        await InvokeAsync(StateHasChanged);
    }
    private void StartTimer()
    {
        _timer.Start();
        _isRunning = true;
    }
    private void StopTimer()
    {
        _timer.Stop();
        _isRunning = false;
    }
    private void ResetTimer()
    {
        _elapsedTime = TimeSpan.Zero;
        StopTimer();
        StateHasChanged();
    }
    public void Dispose()
    {
        _timer.Dispose();
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_jsInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("initializeDragAndDrop", DropZone);
                _jsInitialized = true; // Ensure JS is initialized only once
            }
            catch (Exception ex)
            {
            }
        }
    }
    int numberofFileswithoutreference = 0;
    private async Task REF_FileUpload(InputFileChangeEventArgs e)
    {
        REF_ResetVariables();
        isLoading = true;
        GetErrorsPairsList.Clear();


        foreach (var browserFile in e.GetMultipleFiles(MAX_FILES))
        {
            try
            {
               
                var shortname = await DataManagementService.GetShortCodefromReferencing(browserFile.Name, stringHelper.GetBusinessTypeFromFile(browserFile.Name));
                var extension = Path.GetExtension(browserFile.Name);
                if (browserFile != null && extension == ".xlsx" && !string.IsNullOrWhiteSpace(shortname))
                {
                    spreadsheetFileAndChipColor.Add(new SpreadsheetFileAndChipColor { SpreadsheetFile = browserFile, SpreadsheetFileColor = Color.Primary, IsPassed = true });
                }
                else
                {
                    spreadsheetFileAndChipColor.Add(new SpreadsheetFileAndChipColor { SpreadsheetFile = browserFile, SpreadsheetFileColor = Color.Error, IsPassed = false });
                    numberofFileswithoutreference++;
                }
            }
            catch (Exception)
            {
            }

        }
        if (numberofFileswithoutreference > 0)
        {
            showorHideInsertReferenceButton = "d-block";
            showorHideReferenceButton = "d-none";
        }
        StateHasChanged();
        currentFileCount = spreadsheetFileAndChipColor.Count;
        isLoading = false;
    }
    private void REF_RemoveFile(SpreadsheetFileAndChipColor file)
    {
        spreadsheetFileAndChipColor.Remove(file);
        currentFileCount = spreadsheetFileAndChipColor.Count;
        StateHasChanged();
    }
    private void REF_ClearSeletedFiles()
    {
        spreadsheetFileAndChipColor.Clear();
        currentFileCount = spreadsheetFileAndChipColor.Count;
        fullPastFilesPaths.Clear();
        fullFailedFilesPaths.Clear();
        REF_ResetVariables();
        StateHasChanged();
    }
    string oldselectedPanel = string.Empty;
    private void REF_OnPanelExpandedChanged(string selectedPanel)
    {
        REF_ClearSeletedFiles();
        expandPanelSelectedOption = selectedPanel;
    }
    private async Task REF_DownloadExcelDataStream(byte[] excelData, string targetFilePath)
    {
        string SecuredFileNameOrRawFileName = targetFilePath!;
        if (PRINT_EXCEL_WITH_SECURED_NAME)
        {
            SecuredFileNameOrRawFileName = Path.GetFileName(targetFilePath!);
        }
        else { SecuredFileNameOrRawFileName = REF_GetFileNameFromFile(targetFilePath!); }
        // Trigger download using JavaScript Interop
        await JS.InvokeVoidAsync("downloadFile", SecuredFileNameOrRawFileName, excelData, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
        File.Delete(FullExcelDataFilePath!);
    }
    private string REF_GetFileNameFromFile(string path)
    {
        string item = Path.GetFileName(path);
        item = item.Split("_____")[1];
        item = item.Replace(".xlsx", "_TBC.xlsx");
        return item;
    }
    private void REF_ResetVariables()
    {
        passedRecord.Clear();
        failedRecord.Clear();
