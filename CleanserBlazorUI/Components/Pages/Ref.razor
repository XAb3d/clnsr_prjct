    private void REF_ValidateHeaders(List<string> expectedHeaders, List<string> actualHeaders, SpreadSheetStatusContext spreadSheetStatus)
    {
        int maxLength = Math.Min(expectedHeaders.Count, actualHeaders.Count);
        for (int i = 0; i < maxLength; i++)
        {
            if (!string.Equals(expectedHeaders[i], actualHeaders[i], StringComparison.OrdinalIgnoreCase))
            {
                spreadSheetStatus.InvalidHeaders.Add(new ErrorsPairs(expectedHeaders[i], actualHeaders[i]));
            }
        }
    }
    private void REF_WriteHeaders(IXLWorksheet ws, IXLWorksheet wsu, List<string> headers, int errorIndex)
    {
        for (int i = 0; i < headers.Count; i++)
        {
            ws.Cell(1, i + 1).Value = headers[i];
            wsu.Cell(1, i + 1).Value = headers[i];
        }
        wsu.Cell(1, errorIndex).Value = "--------------- Errors ---------------";
    }
    private void REF_WriteData<T>(List<T> rows, IXLWorksheet ws, IXLWorksheet wsu) where T : class
    {
        int correctDataCellIndex = 2;
        int wrongDataCellIndex = 2;
        bool isDateOfBirtWrong = false;

        foreach (var row in rows)
        {
            isDateOfBirtWrong = REF_IsDateOfBirtWrong(row);
            if (isDateOfBirtWrong)
            {
                REF_WriteRow(ws, row, ref isDateOfBirtWrong, ref correctDataCellIndex);
            }
            else
            {
                REF_WriteRow(wsu, row, ref isDateOfBirtWrong, ref wrongDataCellIndex);
            }
        }
        ws.Columns().AdjustToContents();
