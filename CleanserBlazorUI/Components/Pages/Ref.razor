    public static bool REF_AreAllItemsAvailable(List<string> fileNamesToCheck, List<string> AcceptedFiles)
    {
        if (fileNamesToCheck == null || AcceptedFiles == null)
            return false;

        var availableSet = new HashSet<string>(AcceptedFiles);

        foreach (var item in fileNamesToCheck)
        {
            if (!availableSet.Contains(item))
                return false;
        }

        return true;
    }
