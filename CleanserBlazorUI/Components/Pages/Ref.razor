    private async Task REF_InsertThisAsLatesReference()
    {
        StartTimer();
        closePanels = false;
        passedRecord.Clear();
        failedRecord.Clear();
        progressIsVisible = "d-block";
        var _spreadsheetFileAndChipColor = spreadsheetFileAndChipColor.Where(passed => passed.IsPassed == false).ToList();
        foreach (var item in _spreadsheetFileAndChipColor)
        {
            await INSERTREF_REF_GetSpreadsheetData(item.SpreadsheetFile);
        }
        numberOfPassedCount = $"Passed Files ({passedRecord.Count})";
        numberOffailedCount = failedRecord.Count.ToString();
        progressIsVisible = "d-none";
    }
