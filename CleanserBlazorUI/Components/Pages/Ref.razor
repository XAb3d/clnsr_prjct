    public List<DBIndividualContext> REF_MainMatcherTransformer(List<IndividualRef> savedDatafromOurDatabase, List<DBIndividualContext> recordFromClient)
    {
        foreach (var clientRecord in recordFromClient)
        {
            var matchingSavedRecord = savedDatafromOurDatabase.FirstOrDefault(saved => saved.CreditFacilityAccNum == clientRecord.CreditFacilityAccNum && saved.CustomerID == clientRecord.CustomerID && saved.DisbursementDate == clientRecord.DisbursementDate);

            if (matchingSavedRecord == null)
            {
                clientRecord.Status = string.Empty;
            }
            else
            {
                // Compare DateOfBirth
                if (matchingSavedRecord.DateOfBirth == clientRecord.DateOfBirth)
                {
                    clientRecord.Status = string.Empty;
                }
                else
                {
                    clientRecord.Status = "DOB";
                }
            }
        }
        //DOB

        return recordFromClient;  // Return categorized records
    }
    public string REF_GetNameFromFile(string theFilename)
    {
        string fileFirstPart = theFilename.Split('_').FirstOrDefault();
        string ibrowserFileName = stringHelper.GetFirstPartExcludeLastPart(fileFirstPart, 4);
        return ibrowserFileName;
    }
    public bool REF_IsDateOfBirtWrong<T>(T context) where T : class
    {
        if (typeof(T) == typeof(DBBusinessContext))
        {
            var bc = context as DBBusinessContext;
            if (string.IsNullOrWhiteSpace(bc.Status))
            {
                return true;
            }
        }
        else if (typeof(T) == typeof(DBIndividualContext))
        {
            var ic = context as DBIndividualContext;
            if (string.IsNullOrWhiteSpace(ic.Status))
            {
                return true;
            }
        }
        return false;
    }
