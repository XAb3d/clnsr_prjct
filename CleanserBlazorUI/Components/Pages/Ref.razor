                        var mainMatcherTransformer = REF_MainMatcherTransformer(RefData, ExcelDataRecieved);
                        byte[] ExcelDataTobeDownloaded = await REF_SaveToExcelAsync(mainMatcherTransformer);
                        await REF_DownloadExcelDataStream(ExcelDataTobeDownloaded, FullExcelDataFilePath);
                        File.Delete(FullExcelDataFilePath!);
                        AlertSeverityVisible = "d-none";
                    }
                }

